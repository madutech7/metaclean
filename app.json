{
  "expo": {
    "name": "MetaClean",
    "slug": "cleanfiles",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "metaclean",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.madu.metaclean"
    },
    "android": {
      "package": "com.madu.metaclean",
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020617"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application a besoin d'accéder à vos photos pour y supprimer les métadonnées (en local)."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "L'application a besoin d'accès pour enregistrer la photo nettoyée dans votre galerie.",
          "savePhotosPermission": "L'application a besoin d'enregistrer la photo nettoyée.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "./utils/withFFmpegFix"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
